# =============================
# Sec-Turismo - SeguranĂ§a
# =============================
#
# Estrutura atual:
# - a pĂĄgina inicial fica em /public/index.php;
# - algumas pĂĄginas pĂșblicas ainda sĂŁo servidas por /app/Views/*.php.
#
# Em produĂ§ĂŁo, mantenha este .htaccess na raiz do projeto ou evolua o projeto
# para um roteador Ășnico antes de usar /public como DocumentRoot exclusivo.

Options -Indexes
DirectoryIndex index.php public/index.php

<FilesMatch "(^\.env$|^\.env\..*|^composer\.json$|^composer\.lock$|^README\.md$|^TODO\.md$)">
  Require all denied
</FilesMatch>

RedirectMatch 404 ^/app/(Core|Controllers|Models|Utils)/
RedirectMatch 404 ^/app/config\.php$

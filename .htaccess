Options -Indexes
DirectoryIndex index.php

RewriteEngine On

# Canonical public URLs.
RewriteRule ^public/index\.php$ ./ [R=301,L]
RewriteRule ^app/Views/([A-Za-z0-9_-]+)\.php$ $1 [R=301,L,QSA]
RewriteRule ^app/Controllers/logout\.php$ logout [R=301,L,QSA]

# Public clean routes.
RewriteRule ^logout$ app/Controllers/logout.php [END,QSA]
RewriteRule ^(menu|praias|igarapes|hoteis|mapa_turistico|videos|cat|contatos_uteis|barraca_do_pescador|login|admin|criar|editar|excluir|criar_noticia|editar_noticia|excluir_noticia|criar_video|editar_video|excluir_video|criar_usuario)$ app/Views/$1.php [END,QSA]

<FilesMatch "(^\.env$|^\.env\..*|^composer\.json$|^composer\.lock$|^README\.md$|^TODO\.md$)">
  Require all denied
</FilesMatch>

RewriteRule ^app/(Core|Controllers|Models|Utils)/ - [R=404,L]
RewriteRule ^app/config\.php$ - [R=404,L]
